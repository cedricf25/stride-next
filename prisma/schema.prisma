generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  emailVerified   Boolean  @default(false)
  name            String?
  image           String?

  // Stride-specific fields (Garmin Connect credentials)
  garminUsername   String?
  garminPassword   String?
  displayName     String?
  vo2max          Float?
  weight          Float?
  height          Float?
  restingHR       Int?
  maxHR           Int?
  lastSyncAt      DateTime?

  // Nutrition fields
  birthDate       DateTime?  @db.Date
  gender          String?    // "male" | "female"

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Better Auth relations
  sessions         Session[]
  accounts         Account[]

  // Stride relations
  activities       Activity[]
  sleepRecords     SleepRecord[]
  healthMetrics    HealthMetric[]
  trainingPlans           TrainingPlan[]
  racePredictionBatches   RacePredictionBatch[]
  healthAnalyses          HealthAnalysis[]

  // Nutrition relations
  meals               Meal[]
  favoriteMeals       FavoriteMeal[]
  nutritionGoal       NutritionGoal?
  nutritionAnalyses   NutritionAnalysis[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?   @db.Text
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Activity {
  id                      String   @id @default(cuid())
  garminActivityId        BigInt   @unique
  userId                  String
  user                    User     @relation(fields: [userId], references: [id])

  activityName            String
  activityType            String
  startTimeLocal          DateTime
  startTimeGMT            DateTime?

  // Distance & durée
  distance                Float
  duration                Float
  movingDuration          Float?
  elapsedDuration         Float?

  // Allure & vitesse
  averageSpeed            Float?
  maxSpeed                Float?

  // Fréquence cardiaque
  averageHR               Int?
  maxHR                   Int?

  // Calories
  calories                Int?

  // Élévation
  elevationGain           Float?
  elevationLoss           Float?
  minElevation            Float?
  maxElevation            Float?

  // Cadence & dynamique de course
  averageCadence          Float?
  maxCadence              Float?
  averageStrideLength     Float?
  averageGCT              Float?     // Ground Contact Time (ms)
  averageVerticalOscillation Float?  // (cm)
  averageVerticalRatio    Float?     // (%)

  // Puissance (Running Power)
  averagePower            Float?     // Watts
  maxPower                Float?     // Watts
  normalizedPower         Float?     // Watts (NP)

  // Stamina
  staminaPercent          Float?     // % restant en fin d'activité
  potentialStamina        Float?     // Potentiel stamina

  // Training metrics
  aerobicTrainingEffect   Float?
  anaerobicTrainingEffect Float?
  trainingStressScore     Float?     // TSS
  intensityFactor         Float?
  vo2max                  Float?

  // Conditions
  avgTemperature          Float?
  startLatitude           Float?
  startLongitude          Float?
  locationName            String?

  // Statistiques d'allure calculées (pour analyse IA)
  paceVariability         Float?     // Écart-type de l'allure entre splits (%)
  negativeSplitRatio      Float?     // Ratio 2ème moitié / 1ère moitié (< 1 = negative split)
  fastestSplitKm          Int?       // Numéro du km le plus rapide
  slowestSplitKm          Int?       // Numéro du km le plus lent
  paceDecay               Float?     // % de ralentissement entre début et fin
  evenPaceScore           Int?       // Score de régularité 0-100 (100 = parfait)

  // Metadata
  description             String?    @db.Text

  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  splits                  ActivitySplit[]
  intervals               ActivityInterval[]
  analysis                ActivityAnalysis?
  linkedSession           TrainingSession?

  @@index([userId])
  @@index([startTimeLocal])
}

model ActivitySplit {
  id              String   @id @default(cuid())
  activityId      String
  activity        Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  splitNumber     Int
  splitType       String   @default("km") // "km" ou "lap"
  distance        Float
  duration        Float
  movingDuration  Float?   // Durée en mouvement (sans pauses)
  averageSpeed    Float?
  maxSpeed        Float?   // Vitesse max sur ce split
  averageHR       Int?
  maxHR           Int?
  averageCadence  Float?
  maxCadence      Float?   // Cadence max
  elevationGain   Float?
  elevationLoss   Float?

  // Dynamique de course enrichie
  averageGCT              Float?   // Ground Contact Time (ms)
  groundContactBalance    Float?   // Balance gauche/droite (%)
  averageStrideLength     Float?   // Longueur de foulée (m)
  averageVerticalOscillation Float? // Oscillation verticale (cm)
  averageVerticalRatio    Float?   // Ratio vertical (%)

  // Puissance (si disponible)
  averagePower    Float?   // Watts moyen sur ce split

  @@unique([activityId, splitNumber, splitType])
  @@index([activityId])
}

model ActivityAnalysis {
  id          String   @id @default(cuid())
  activityId  String   @unique
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  analysis    String   @db.LongText
  model       String   @default("gemini-3-flash-preview")
  createdAt   DateTime @default(now())

  @@index([activityId])
}

model ActivityInterval {
  id              String   @id @default(cuid())
  activityId      String
  activity        Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  intervalType    String   // INTERVAL_WARMUP, INTERVAL_ACTIVE, INTERVAL_RECOVERY, INTERVAL_COOLDOWN, RWD_RUN, RWD_WALK
  intervalOrder   Int      // Ordre dans la séance (0 = premier intervalle)
  distance        Float    // Distance totale de cet intervalle (m)
  duration        Float    // Durée totale (s)
  noOfSplits      Int      // Nombre de répétitions de ce type

  // Moyennes
  averageSpeed    Float?   // m/s
  averageHR       Int?
  maxHR           Int?
  averageCadence  Float?
  averageGCT      Float?   // Ground Contact Time (ms)
  averageStrideLength Float?

  // Élévation
  elevationGain   Float?
  elevationLoss   Float?

  @@unique([activityId, intervalOrder])
  @@index([activityId])
}

model SleepRecord {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])

  calendarDate        DateTime @db.Date
  sleepStartTimestamp DateTime?
  sleepEndTimestamp   DateTime?

  totalSleepSeconds   Int?
  deepSleepSeconds    Int?
  lightSleepSeconds   Int?
  remSleepSeconds     Int?
  awakeSleepSeconds   Int?

  sleepScore          Int?
  sleepQualifier      String?

  avgOvernightHRV     Float?
  restingHeartRate    Int?
  avgSleepStress      Float?
  bodyBatteryChange   Int?
  startBodyBattery    Int?
  endBodyBattery      Int?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, calendarDate])
  @@index([userId])
  @@index([calendarDate])
}

model HealthMetric {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])

  calendarDate        DateTime @db.Date

  restingHeartRate    Int?
  maxHeartRate        Int?
  minHeartRate        Int?

  weight              Float?
  bmi                 Float?
  bodyFatPercentage   Float?
  muscleMass          Float?

  totalSteps          Int?
  totalDistance        Float?
  activeCalories      Int?
  totalCalories       Int?

  stressLevel         Int?
  bodyBattery         Int?

  // Intensity minutes (données Garmin)
  moderateIntensityMinutes  Int?  // Minutes modérées (zone aérobie faible)
  vigorousIntensityMinutes  Int?  // Minutes vigoureuses (zone aérobie élevée)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, calendarDate])
  @@index([userId])
  @@index([calendarDate])
}

model TrainingPlan {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])

  name                String
  raceType            String   // "10km", "semi-marathon", "marathon", "trail"
  raceDate            DateTime? @db.Date
  startDate           DateTime? @db.Date
  targetDistance      Float?   // km (pour trail)
  targetElevation     Float?   // D+ (pour trail)
  targetTime          String?  // objectif chrono
  daysPerWeek         Int
  longRunDay          String   // "lundi" → "dimanche"
  planningMode        String   @default("time") // "time" ou "distance" - mode de planification par défaut
  includeStrength     Boolean  @default(false)
  strengthFrequency   Int?     // 1 à 4 séances de renforcement par semaine
  status              String   @default("active") // "active", "completed", "archived"
  goalProbability     Int?
  goalAssessment      String?  @db.Text
  currentVersion      Int      @default(1)
  lastUpdatedAt       DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  weeks               TrainingWeek[]
  versions            TrainingPlanVersion[]

  @@index([userId])
}

model TrainingPlanVersion {
  id              String   @id @default(cuid())
  planId          String
  plan            TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  versionNumber   Int
  createdAt       DateTime @default(now())
  snapshot        String   @db.LongText  // JSON des semaines/sessions

  // Changelog IA
  changelogSummary  String?  @db.Text
  changelogDetails  String?  @db.LongText

  // Contexte
  triggerReason   String?  // "initial", "manual_update", "backfill"

  // Métriques diff
  sessionsAdded    Int @default(0)
  sessionsRemoved  Int @default(0)
  sessionsModified Int @default(0)
  volumeChange     Float?

  @@unique([planId, versionNumber])
  @@index([planId])
}

model TrainingWeek {
  id              String   @id @default(cuid())
  planId          String
  plan            TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  weekNumber      Int
  theme           String   // "Base", "Développement", "Affûtage", etc.
  totalVolume     Float?   // km total prévu

  @@unique([planId, weekNumber])
  @@index([planId])

  sessions        TrainingSession[]
}

model TrainingSession {
  id              String   @id @default(cuid())
  weekId          String
  week            TrainingWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  dayOfWeek       String   // "lundi" → "dimanche"
  sessionType     String   // "easy", "tempo", "interval", "long_run", "recovery", "rest"
  title           String
  description     String   @db.Text
  distance        Float?   // km
  duration        Int?     // minutes
  targetPace      String?  // ex: "5:30 /km"
  targetHRZone    String?  // ex: "Z2", "Z3-Z4"
  intensity       String   @default("moderate") // "low", "moderate", "high", "very_high"
  displayMode     String?  // "time" ou "distance" - override individuel (null = utilise planningMode du plan)
  workoutSummary  String?  // Résumé court pour intervalles: "3×10' Z4", "8×400m", "2×(6×200m)"
  elevationGain   Int?     // D+ en mètres (trail uniquement)
  terrainType     String?  // "route", "chemin", "sentier technique", "montagne", etc.
  exercises       String?  @db.Text // JSON array d'exercices pour séances strength
  completed       Boolean  @default(false)

  // Lien vers l'activité réelle correspondante
  linkedActivityId  String?   @unique
  linkedActivity    Activity? @relation(fields: [linkedActivityId], references: [id], onDelete: SetNull)
  matchScore        Int?      // 0-100, qualité du match planifié/réalisé

  @@index([weekId])
}

model RacePredictionBatch {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  generatedAt     DateTime @default(now())
  summary         String   @db.Text
  contextSnapshot String   @db.LongText  // JSON: données utilisées pour la génération
  recoveryImpact  String?  @db.Text      // Impact de l'état de récupération
  recommendations String?  @db.Text      // Recommandations d'entraînement
  avgConfidence   Int?

  predictions     RacePrediction[]

  @@index([userId])
  @@index([generatedAt])
}

model RacePrediction {
  id              String   @id @default(cuid())
  batchId         String
  batch           RacePredictionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  distance        String   // "5km", "10km", "semi-marathon", "marathon", "trail"
  label           String
  predictedTime   String
  predictedPace   String
  confidence      Int      // 0-100
  comment         String   @db.Text

  // Détails enrichis
  estimatedSplits String?  @db.Text  // JSON: tableau des splits estimés
  raceStrategy    String?  @db.Text  // Stratégie de course
  heartRateZones  String?  @db.Text  // JSON: zones FC par phase

  @@index([batchId])
}

model HealthAnalysis {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  pageType        String   // "hrv", "sleep", "heart-rate", "weight", "body-battery", "steps"
  analysis        String   @db.LongText
  model           String   @default("gemini-3-flash-preview")

  // Période analysée
  periodStart     DateTime @db.Date
  periodEnd       DateTime @db.Date
  dataPointsCount Int      @default(0)

  createdAt       DateTime @default(now())

  @@unique([userId, pageType])
  @@index([userId])
}

// ==========================================
// NUTRITION MODELS
// ==========================================

model NutritionGoal {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Métabolisme calculé
  bmr             Int      // Basal Metabolic Rate (kcal)
  tdee            Int      // Total Daily Energy Expenditure (kcal)

  // Objectifs
  targetCalories  Int      // Objectif calorique quotidien
  targetProtein   Int?     // grammes
  targetCarbs     Int?     // grammes
  targetFat       Int?     // grammes

  // Configuration déficit/surplus
  weeklyWeightGoal Float?  // kg/semaine (+/- : gain/perte)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Meal {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date            DateTime @db.Date
  mealType        String   // "breakfast" | "lunch" | "dinner" | "snack"
  name            String?
  notes           String?  @db.Text

  // Photo (optionnel)
  imageData       String?  @db.LongText
  imageMimeType   String?

  // Totaux calculés
  totalCalories   Int      @default(0)
  totalProtein    Float    @default(0)
  totalCarbs      Float    @default(0)
  totalFat        Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  foods           Food[]
  analysis        MealAnalysis?

  @@index([userId, date])
  @@index([date])
}

model Food {
  id          String   @id @default(cuid())
  mealId      String
  meal        Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  name        String
  quantity    Float
  unit        String   // "g" | "ml" | "portion"

  calories    Int
  protein     Float
  carbs       Float
  fat         Float

  source      String   @default("manual") // "manual" | "ai_vision" | "favorite"
  confidence  Int?     // 0-100 pour IA

  createdAt   DateTime @default(now())

  @@index([mealId])
}

model FavoriteMeal {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  mealType        String   // "breakfast" | "lunch" | "dinner" | "snack"

  // Totaux pré-calculés
  totalCalories   Int
  totalProtein    Float
  totalCarbs      Float
  totalFat        Float

  // Aliments en JSON
  foods           String   @db.Text  // JSON array des aliments

  usageCount      Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model MealAnalysis {
  id        String   @id @default(cuid())
  mealId    String   @unique
  meal      Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  analysis  String   @db.LongText
  model     String   @default("gemini-2.0-flash")

  createdAt DateTime @default(now())
}

model NutritionAnalysis {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  analysisType  String   // "daily" | "weekly" | "trends"
  analysis      String   @db.LongText
  model         String   @default("gemini-2.0-flash")

  periodStart   DateTime @db.Date
  periodEnd     DateTime @db.Date

  createdAt     DateTime @default(now())

  @@unique([userId, analysisType])
  @@index([userId])
}
