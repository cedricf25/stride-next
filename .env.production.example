# ============================================
# Stride Dashboard - Configuration Production
# ============================================
# Copiez ce fichier vers .env.production et remplissez les valeurs

# ============================================
# Base de données MariaDB
# ============================================
# Mot de passe pour l'utilisateur 'stride'
DB_PASSWORD=votre_mot_de_passe_securise_ici

# Mot de passe root MariaDB (pour administration)
DB_ROOT_PASSWORD=votre_mot_de_passe_root_securise

# URL de connexion (ne pas modifier, utilise les variables ci-dessus)
DATABASE_URL=mysql://stride:${DB_PASSWORD}@db:3306/stride

# ============================================
# Google Gemini AI
# ============================================
GEMINI_API_KEY=votre_cle_api_gemini

# ============================================
# Better Auth
# ============================================
# URL publique de l'application (avec https en production)
BETTER_AUTH_URL=https://votre-domaine.com
NEXT_PUBLIC_BETTER_AUTH_URL=https://votre-domaine.com

# Secret pour les sessions (générez avec: openssl rand -base64 32)
BETTER_AUTH_SECRET=votre_secret_genere_aleatoirement

# ============================================
# Domaine (optionnel)
# ============================================
# Si vous avez un nom de domaine, décommentez et configurez
# DOMAIN=stride.votre-domaine.com
